# === MinIO (S3-compatible) ===
MINIO_ROOT_USER=à_modifier
MINIO_ROOT_PASSWORD=à_modifier
MINIO_BUCKET=mlflow-artifacts

# === S3/MinIO credentials (shared by MLflow, Airflow, API) ===
AWS_ACCESS_KEY_ID=à_modifier
AWS_SECRET_ACCESS_KEY=à_modifier
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# === MLflow (serveur distant du prof) ===
MLFLOW_TRACKING_URI=à modifier 
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/

# === API ===
API_HOST=0.0.0.0
API_PORT=8000

# === WebApp ===
API_URL=http://api:8000
